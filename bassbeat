#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG="$HOME/.config/bassbeat/config.toml"
[ ! -f "$CONFIG" ] && CONFIG="$SCRIPT_DIR/config.toml"

case "$1" in
    --kill|--stop)
        pkill -f "python3.*main.py.*bassbeat" 2>/dev/null
        pkill -f "bassbeat" 2>/dev/null
        echo "BassBeat stopped"
        exit 0
        ;;
    --config)
        cat "$CONFIG"
        exit 0
        ;;
    --edit)
        ${EDITOR:-${VISUAL:-xdg-open}} "$CONFIG"
        exit 0
        ;;
    --config-path)
        echo "$CONFIG"
        exit 0
        ;;
    --help|-h)
        echo "Usage: bassbeat [OPTIONS]"
        echo ""
        echo "Options:"
        echo "  --kill         Stop running instance"
        echo "  --config       Print current config"
        echo "  --edit         Open config in editor"
        echo "  --config-path  Print config file path"
        echo "  --help         Show this help"
        echo ""
        echo "Config: $CONFIG"
        exit 0
        ;;
esac

if command -v pw-metadata &>/dev/null; then
    pw-metadata -n settings 0 clock.force-quantum 128 &>/dev/null
fi

exec "$SCRIPT_DIR/.venv/bin/python3" "$SCRIPT_DIR/main.py" --config "$CONFIG" "$@" 2>/dev/null
